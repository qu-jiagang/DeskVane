{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DeskVane",
  "version": "0.1.0",
  "identifier": "com.deskvane.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "DeskVane",
        "width": 1080,
        "height": 720,
        "minWidth": 820,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../deskvane/assets/deskvane-icon.png",
      "../deskvane/assets/deskvane-icon.svg"
    ]
  }
}
